# ==============================================================================
# KITABILL CLEAN GITIGNORE (Whitelist-based)
# Ensures NO temporary files, debug scripts, dumps, or backups ever get committed.
# ==============================================================================

# 1. Ignore everything by default
/*

# 2. Allow core Laravel folders
!/app/
!/bootstrap/
!/config/
!/database/
!/public/
!/resources/
!/routes/
!/tests/
!/lang/
!/storage/

# 3. Allow standard configuration & run files at root
!.gitignore
!.env.example
!.editorconfig
!.gitattributes
!composer.json
!composer.lock
!package.json
!package-lock.json
!vite.config.js
!postcss.config.js
!tailwind.config.js
!artisan
!phpunit.xml
!ecosystem.config.cjs
!README.md

# 4. Standard Laravel ignores inside allowed folders
/bootstrap/cache/*
/public/build
/public/hot
/public/storage
/storage/app/*
/storage/framework/*
/storage/logs/*
/storage/*.key
/vendor
/node_modules

# 5. Global Blacklist for trash, sql, text logs, and backups (even inside folders)
* copy*
*backup*
*copy.*
*copy *
*.log
*.sql
*.txt
*.bak
*.sqlite
*.db
